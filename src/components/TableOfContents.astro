---
// 右侧目录侧栏 + 圆形阅读进度环（参考 missuo.me，移植自原 Hugo toc_sidebar）
// 目录在客户端从文章标题自动生成；大屏显示，小屏隐藏。
---
<aside class="toc-sidebar" aria-label="目录" hidden>
  <div class="toc-progress" title="阅读进度">
    <svg class="toc-ring" viewBox="0 0 36 36" aria-hidden="true">
      <circle class="toc-ring-bg" cx="18" cy="18" r="15.9155" />
      <circle class="toc-ring-fg" cx="18" cy="18" r="15.9155" />
    </svg>
    <span class="toc-pct">0%</span>
  </div>
  <nav class="toc-nav">
    <div class="toc-title">目录</div>
    <ul class="toc-list"></ul>
  </nav>
</aside>

<style>
  .toc-sidebar {
    position: fixed;
    top: 6rem;
    left: calc(50% + 24rem + 1.75rem);
    width: 13.5rem;
    max-height: 72vh;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    z-index: 5;
  }
  @media (max-width: 1279px) {
    .toc-sidebar { display: none !important; }
  }
  .toc-progress {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--muted-foreground);
    font-size: 0.78rem;
  }
  .toc-ring { width: 2.25rem; height: 2.25rem; transform: rotate(-90deg); }
  .toc-ring-bg { fill: none; stroke: var(--border); stroke-width: 3; }
  .toc-ring-fg {
    fill: none;
    stroke: var(--accent);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 100 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 0.12s linear;
  }
  .toc-title {
    margin-bottom: 0.5rem;
    color: var(--foreground);
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
  .toc-list { list-style: none; margin: 0; padding: 0; }
  .toc-list li { margin: 0; }
  .toc-link {
    display: block;
    padding: 0.28rem 0 0.28rem 0.75rem;
    color: var(--muted-foreground);
    font-size: 0.82rem;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .toc-link:hover { color: var(--foreground); }
  .toc-link.active { color: var(--accent); font-weight: 500; }
  .toc-level-3 .toc-link { padding-left: 1.5rem; font-size: 0.78rem; }
  .toc-level-4 .toc-link { padding-left: 2.25rem; font-size: 0.76rem; }
</style>

<script>
  function initToc() {
    const sidebar = document.querySelector<HTMLElement>(".toc-sidebar");
    const article = document.getElementById("article");
    if (!sidebar || !article) return;
    if ((sidebar as any).__tocInit) return;
    (sidebar as any).__tocInit = true;

    const list = sidebar.querySelector<HTMLElement>(".toc-list")!;
    const ringFg = sidebar.querySelector<SVGCircleElement>(".toc-ring-fg")!;
    const pctEl = sidebar.querySelector<HTMLElement>(".toc-pct")!;

    const headings = Array.from(
      article.querySelectorAll<HTMLElement>("h2[id], h3[id], h4[id]")
    );
    if (headings.length < 2) {
      sidebar.hidden = true;
      return;
    }
    sidebar.hidden = false;

    list.innerHTML = "";
    const links: HTMLAnchorElement[] = [];
    for (const h of headings) {
      const li = document.createElement("li");
      li.className = "toc-level-" + h.tagName.substring(1);
      const a = document.createElement("a");
      a.className = "toc-link";
      a.href = "#" + h.id;
      a.dataset.target = h.id;
      a.textContent = h.textContent?.replace(/#$/, "").trim() || "";
      a.title = a.textContent;
      li.appendChild(a);
      list.appendChild(li);
      links.push(a);
    }

    const activate = (id: string) => {
      links.forEach(l => l.classList.toggle("active", l.dataset.target === id));
    };

    const visible = new Map<string, number>();
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(e => {
          if (e.isIntersecting) visible.set((e.target as HTMLElement).id, e.boundingClientRect.top);
          else visible.delete((e.target as HTMLElement).id);
        });
        if (visible.size) {
          const [id] = Array.from(visible.entries()).sort((a, b) => a[1] - b[1])[0];
          activate(id);
          return;
        }
        const current = headings.filter(h => h.getBoundingClientRect().top < 130).pop();
        if (current) activate(current.id);
      },
      { rootMargin: "-110px 0px -65% 0px", threshold: [0, 1] }
    );
    headings.forEach(h => observer.observe(h));
    activate(headings[0].id);

    const onScroll = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? Math.min(100, Math.max(0, (h.scrollTop / max) * 100)) : 0;
      ringFg.style.strokeDashoffset = String(100 - pct);
      pctEl.textContent = Math.round(pct) + "%";
    };
    document.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener("astro:page-load", initToc);
  initToc();
</script>
