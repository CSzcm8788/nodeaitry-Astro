---
/**
 * Comments — 对接同一个 Cloudflare Worker 后端（不变）：
 *   GET/POST {api}/v1/comments
 * pageKey 必须等于线上 Hugo 的 RelPermalink（带尾斜杠，如 /posts/hello-nodeaitry/）。
 * 样式参照 missuo.me：小圆头像、相对时间、"作者"徽章、灰色 · 分隔的设备信息行。
 * 注意：列表为 JS 动态生成，样式必须用 is:global，否则不会作用到动态元素（头像会变巨大）。
 */
interface Props {
  pageKey: string;
  pageUrl: string;
  pageTitle: string;
  pageSize?: number;
}

const { pageKey, pageUrl, pageTitle, pageSize = 20 } = Astro.props;

const api = import.meta.env.DEV
  ? "http://localhost:8787"
  : "https://comments.nodeaitry.com";
---

<section
  id="ct-comments"
  class="ct-wrap"
  data-api={api.replace(/\/$/, "")}
  data-page-key={pageKey}
  data-page-url={pageUrl}
  data-page-title={pageTitle}
  data-page-size={pageSize}
>
  <h2 class="ct-title">评论 <span id="ct-count">0</span></h2>
  <p class="ct-subtitle">读完了？留个言吧。</p>
  <form id="ct-form" class="ct-form">
    <div class="ct-reply-line">
      <span id="ct-reply-hint" class="ct-reply-hint" hidden></span>
      <button id="ct-reply-cancel" class="ct-link-button" type="button" hidden>取消</button>
    </div>
    <div class="ct-form-row">
      <input id="ct-name" name="name" autocomplete="name" maxlength="80" placeholder="昵称" required />
      <input id="ct-email" name="email" autocomplete="email" maxlength="120" type="email" placeholder="邮箱（用于头像）" />
      <input id="ct-link" name="link" autocomplete="url" maxlength="240" type="url" placeholder="网站（可选）" />
    </div>
    <textarea id="ct-content" name="content" maxlength="4000" rows="4" placeholder="写下你的评论…" required></textarea>
    <div class="ct-form-actions">
      <p id="ct-message" class="ct-message"></p>
      <button id="ct-submit" class="ct-button" type="submit">提交</button>
    </div>
  </form>
  <div id="ct-list" class="ct-list"></div>
  <p id="ct-empty" class="ct-empty" hidden>还没有评论。</p>
  <button id="ct-more" class="ct-button ct-more" type="button" hidden>加载更多</button>
</section>

<style is:global>
  #ct-comments{margin:3rem 0 0;padding-top:1.25rem;border-top:1px solid var(--border)}
  #ct-comments .ct-title{margin:0 0 .25rem;font-size:1.35rem}
  #ct-comments .ct-title span{color:var(--muted-foreground);font-size:.95rem;font-weight:500}
  #ct-comments .ct-subtitle{margin:0 0 1.25rem;color:var(--muted-foreground);font-size:.9rem}
  #ct-comments .ct-form{margin-bottom:.5rem}
  #ct-comments .ct-form-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.6rem;margin-bottom:.6rem}
  #ct-comments .ct-form input,#ct-comments .ct-form textarea{width:100%;box-sizing:border-box;border:1px solid transparent;border-radius:8px;background:var(--muted);color:var(--foreground);padding:.6rem .8rem;font:inherit}
  #ct-comments .ct-form input::placeholder,#ct-comments .ct-form textarea::placeholder{color:var(--muted-foreground)}
  #ct-comments .ct-form input:focus,#ct-comments .ct-form textarea:focus{outline:none;border-color:var(--accent);background:var(--background)}
  #ct-comments .ct-form textarea{resize:vertical;line-height:1.6;min-height:5.5rem}
  #ct-comments .ct-form-actions{display:flex;align-items:center;gap:.75rem}
  #ct-comments .ct-button{border:0;border-radius:999px;background:var(--accent);color:var(--accent-foreground);cursor:pointer;font-weight:600;padding:.5rem 1.4rem}
  #ct-comments .ct-button:disabled{cursor:not-allowed;opacity:.55}
  #ct-comments .ct-link-button{border:0;background:transparent;color:var(--muted-foreground);cursor:pointer;padding:0}
  #ct-comments .ct-reply-line{display:flex;align-items:center;gap:.5rem;min-height:1.4rem;margin-bottom:.35rem}
  #ct-comments .ct-reply-hint{border-radius:999px;background:var(--muted);color:var(--muted-foreground);font-size:.78rem;padding:.15rem .55rem}
  #ct-comments .ct-message{flex:1;margin:0;color:var(--muted-foreground);font-size:.82rem}
  #ct-comments .ct-list{margin-top:1.6rem}
  #ct-comments .ct-item{display:flex;gap:.7rem;padding:1.1rem 0;border-bottom:1px solid var(--border)}
  #ct-comments .ct-avatar{flex:0 0 44px;width:44px;height:44px;border-radius:50%;object-fit:cover;outline:1px solid var(--border)}
  #ct-comments .ct-body{flex:1;min-width:0}
  #ct-comments .ct-meta-line{display:flex;align-items:center;flex-wrap:wrap;gap:.45rem}
  #ct-comments .ct-author{color:var(--foreground);font-size:.95rem;font-weight:600}
  #ct-comments .ct-time{color:var(--muted-foreground);font-size:.78rem}
  #ct-comments .ct-badge-admin{display:inline-flex;align-items:center;border-radius:5px;background:color-mix(in srgb,var(--accent) 16%,transparent);color:var(--accent);font-size:.7rem;font-weight:500;line-height:1.4;padding:.02rem .45rem}
  #ct-comments .ct-content{margin-top:.4rem;white-space:pre-wrap;word-break:break-word;line-height:1.7;color:var(--foreground);font-size:.95rem}
  #ct-comments .ct-info{margin-top:.5rem;color:var(--muted-foreground);font-size:.76rem}
  #ct-comments .ct-reply-btn{margin-top:.45rem;border:0;background:transparent;color:var(--muted-foreground);cursor:pointer;font-size:.8rem;padding:0}
  #ct-comments .ct-reply-btn:hover,#ct-comments .ct-link-button:hover{color:var(--accent)}
  #ct-comments .ct-children{margin-top:.9rem}
  #ct-comments .ct-form-inline{margin-top:.9rem}
  #ct-comments .ct-empty{margin:1.5rem 0;color:var(--muted-foreground);text-align:center}
  #ct-comments .ct-more{width:100%;margin-top:1rem;background:transparent;color:var(--muted-foreground);border:1px solid var(--border)}
  @media(max-width:720px){#ct-comments .ct-form-row{grid-template-columns:1fr}}
</style>

<script>
  function initComments() {
    const root = document.getElementById("ct-comments");
    if (!root || (root as any).__ctInit) return;
    (root as any).__ctInit = true;
    const api = String(root.dataset.api || "").replace(/\/$/, "");
    if (!api) return;

    const state = {
      page: 1,
      pageSize: Number(root.dataset.pageSize || 20),
      totalPages: 1,
      total: 0,
      loading: false,
      parentId: null as number | null,
      parentName: "",
      comments: [] as any[],
      seenIds: new Set<number>(),
    };

    const pageKey = root.dataset.pageKey || window.location.pathname;
    const pageUrl = root.dataset.pageUrl || window.location.href;
    const pageTitle = root.dataset.pageTitle || document.title;
    const list = document.getElementById("ct-list")!;
    const empty = document.getElementById("ct-empty")!;
    const count = document.getElementById("ct-count")!;
    const more = document.getElementById("ct-more") as HTMLButtonElement;
    const form = document.getElementById("ct-form") as HTMLFormElement;
    const formParent = form.parentNode!;
    const formNext = form.nextSibling;
    const submit = document.getElementById("ct-submit") as HTMLButtonElement;
    const message = document.getElementById("ct-message")!;
    const replyHint = document.getElementById("ct-reply-hint")!;
    const replyCancel = document.getElementById("ct-reply-cancel")!;
    const nameInput = document.getElementById("ct-name") as HTMLInputElement;
    const emailInput = document.getElementById("ct-email") as HTMLInputElement;
    const linkInput = document.getElementById("ct-link") as HTMLInputElement;
    const contentInput = document.getElementById("ct-content") as HTMLTextAreaElement;
    const profileKey = "ct_comment_profile_v1";

    try {
      const saved = JSON.parse(localStorage.getItem(profileKey) || "{}");
      if (typeof saved.name === "string") nameInput.value = saved.name;
      if (typeof saved.email === "string") emailInput.value = saved.email;
      if (typeof saved.link === "string") linkInput.value = saved.link;
    } catch {}

    function showMessage(text: string, isError = false) {
      message.textContent = text || "";
      (message as HTMLElement).style.color = isError ? "#dc2626" : "";
    }

    function relTime(value: any) {
      const t = new Date(value).getTime();
      if (!Number.isFinite(t)) return String(value || "");
      const diff = Date.now() - t;
      const s = Math.floor(diff / 1000);
      if (s < 60) return "刚刚";
      const m = Math.floor(s / 60);
      if (m < 60) return m + "分钟前";
      const h = Math.floor(m / 60);
      if (h < 24) return h + "小时前";
      const d = Math.floor(h / 24);
      if (d < 30) return d + "天前";
      const mo = Math.floor(d / 30);
      if (mo < 12) return mo + "个月前";
      return Math.floor(mo / 12) + "年前";
    }

    function flagEmoji(code: any) {
      const cc = String(code || "").trim().toUpperCase();
      if (!/^[A-Z]{2}$/.test(cc)) return "";
      return String.fromCodePoint(...[...cc].map(ch => 127397 + ch.charCodeAt(0)));
    }

    function resetFormLocation() {
      form.classList.remove("ct-form-inline");
      formParent.insertBefore(form, formNext);
    }

    function updateReplyUi() {
      if (!state.parentId) {
        replyHint.hidden = true;
        replyCancel.hidden = true;
        replyHint.textContent = "";
        resetFormLocation();
        return;
      }
      replyHint.hidden = false;
      replyCancel.hidden = false;
      replyHint.textContent = `回复 ${state.parentName || "#" + state.parentId}`;
    }

    function treeFromRows(rows: any[]) {
      const map = new Map<number, any>();
      rows.forEach(row => map.set(Number(row.id), { ...row, id: Number(row.id), children: [] }));
      const roots: any[] = [];
      map.forEach(row => {
        const parentId = Number(row.parentId);
        if (Number.isFinite(parentId) && parentId > 0 && map.has(parentId)) {
          map.get(parentId).children.push(row);
        } else {
          roots.push(row);
        }
      });
      const sortRows = (items: any[]) => {
        items.sort((a, b) => new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime() || Number(a.id) - Number(b.id));
        items.forEach(item => sortRows(item.children));
      };
      sortRows(roots);
      return roots;
    }

    function renderComment(comment: any) {
      const item = document.createElement("article");
      item.className = "ct-item";

      const avatar = document.createElement("img");
      avatar.className = "ct-avatar";
      avatar.alt = `${comment.authorName || "Anonymous"} avatar`;
      avatar.loading = "lazy";
      avatar.src = comment.avatarUrl || "https://www.gravatar.com/avatar/?s=96&d=mp&r=g";

      const body = document.createElement("div");
      body.className = "ct-body";

      const meta = document.createElement("div");
      meta.className = "ct-meta-line";
      const author = document.createElement("span");
      author.className = "ct-author";
      author.textContent = comment.authorName || "Anonymous";
      meta.appendChild(author);
      if (comment.isAdmin) {
        const badge = document.createElement("span");
        badge.className = "ct-badge-admin";
        badge.textContent = "作者";
        meta.appendChild(badge);
      }
      const time = document.createElement("span");
      time.className = "ct-time";
      time.textContent = relTime(comment.createdAt);
      meta.appendChild(time);

      const text = document.createElement("div");
      text.className = "ct-content";
      text.textContent = comment.content || "";

      const parts: string[] = [];
      if (comment.browser) parts.push(String(comment.browser));
      if (comment.os) parts.push(String(comment.os));
      if (comment.ipCountry) parts.push(`${flagEmoji(comment.ipCountryCode)} ${comment.ipCountry}`.trim());
      const net = [String(comment.ipAsn || "").trim(), String(comment.ipAsOrg || "").trim()].filter(Boolean).join(" ");
      if (net) parts.push(net);

      body.appendChild(meta);
      body.appendChild(text);
      if (parts.length) {
        const info = document.createElement("div");
        info.className = "ct-info";
        info.textContent = parts.join(" · ");
        body.appendChild(info);
      }

      const reply = document.createElement("button");
      reply.className = "ct-reply-btn";
      reply.type = "button";
      reply.textContent = "回复";
      reply.addEventListener("click", () => {
        state.parentId = Number(comment.id);
        state.parentName = String(comment.authorName || "");
        updateReplyUi();
        form.classList.add("ct-form-inline");
        body.appendChild(form);
        contentInput.focus();
      });
      body.appendChild(reply);

      if (Array.isArray(comment.children) && comment.children.length) {
        const children = document.createElement("div");
        children.className = "ct-children";
        comment.children.forEach((child: any) => children.appendChild(renderComment(child)));
        body.appendChild(children);
      }

      item.appendChild(avatar);
      item.appendChild(body);
      return item;
    }

    function render() {
      list.innerHTML = "";
      treeFromRows(state.comments).forEach(comment => list.appendChild(renderComment(comment)));
      empty.hidden = state.total !== 0;
    }

    async function load(reset = false) {
      if (state.loading) return;
      state.loading = true;
      more.disabled = true;
      try {
        if (reset) {
          state.page = 1;
          state.comments = [];
          state.seenIds = new Set();
        }
        const url = new URL(`${api}/v1/comments`);
        url.searchParams.set("pageKey", pageKey);
        url.searchParams.set("page", String(state.page));
        url.searchParams.set("pageSize", String(state.pageSize));
        const response = await fetch(url.toString(), { method: "GET", credentials: "omit" });
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data?.error?.message || `加载评论失败 (${response.status})`);
        state.total = Number(data.pagination?.total || 0);
        state.totalPages = Number(data.pagination?.totalPages || 1);
        count.textContent = String(state.total);
        (Array.isArray(data.comments) ? data.comments : []).forEach((comment: any) => {
          const id = Number(comment.id);
          if (!Number.isFinite(id) || state.seenIds.has(id)) return;
          state.seenIds.add(id);
          state.comments.push(comment);
        });
        render();
        more.hidden = !(state.page < state.totalPages);
        more.disabled = false;
      } catch (error) {
        showMessage(error instanceof Error ? error.message : "加载评论失败", true);
      } finally {
        state.loading = false;
      }
    }

    more.addEventListener("click", async () => {
      if (state.page >= state.totalPages || state.loading) return;
      state.page += 1;
      await load(false);
    });

    replyCancel.addEventListener("click", () => {
      state.parentId = null;
      state.parentName = "";
      showMessage("");
      updateReplyUi();
    });

    form.addEventListener("submit", async event => {
      event.preventDefault();
      if (state.loading) return;
      const payload = {
        pageUrl,
        pageKey,
        pageTitle,
        authorName: String(nameInput.value || "").trim(),
        authorEmail: String(emailInput.value || "").trim(),
        authorLink: String(linkInput.value || "").trim(),
        content: String(contentInput.value || "").trim(),
        parentId: state.parentId,
      };
      if (!payload.authorName || !payload.content) {
        showMessage("昵称和评论内容为必填项。", true);
        return;
      }
      state.loading = true;
      submit.disabled = true;
      showMessage("提交中...");
      try {
        localStorage.setItem(profileKey, JSON.stringify({ name: payload.authorName, email: payload.authorEmail, link: payload.authorLink }));
        const response = await fetch(`${api}/v1/comments`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data?.error?.message || `发表评论失败 (${response.status})`);
        showMessage(data.comment?.status === "pending" ? "已提交，等待审核。" : "评论已发表。");
        contentInput.value = "";
        state.parentId = null;
        state.parentName = "";
        updateReplyUi();
        state.loading = false;
        await load(true);
      } catch (error) {
        showMessage(error instanceof Error ? error.message : "发表评论失败", true);
      } finally {
        state.loading = false;
        submit.disabled = false;
      }
    });

    updateReplyUi();
    load(true);
  }

  document.addEventListener("astro:page-load", initComments);
  initComments();
</script>
