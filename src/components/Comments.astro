---
/**
 * Comments — ported from the Hugo PaperMod custom comment widget.
 * Talks to the SAME Cloudflare Worker backend (unchanged):
 *   GET/POST {api}/v1/comments
 * pageKey MUST equal the live Hugo RelPermalink (e.g. "/posts/hello-nodeaitry/")
 * so existing comments stay attached after the migration.
 */
interface Props {
  pageKey: string;
  pageUrl: string;
  pageTitle: string;
  pageSize?: number;
}

const { pageKey, pageUrl, pageTitle, pageSize = 20 } = Astro.props;

// Local dev hits the local Worker; production hits the live comments API.
const api = import.meta.env.DEV
  ? "http://localhost:8787"
  : "https://comments.nodeaitry.com";
---

<section
  id="ct-comments"
  class="ct-wrap"
  data-api={api.replace(/\/$/, "")}
  data-page-key={pageKey}
  data-page-url={pageUrl}
  data-page-title={pageTitle}
  data-page-size={pageSize}
>
  <h2 class="ct-title">评论 <span id="ct-count">0</span></h2>
  <form id="ct-form" class="ct-form">
    <div class="ct-reply-line">
      <span id="ct-reply-hint" class="ct-reply-hint" hidden></span>
      <button id="ct-reply-cancel" class="ct-link-button" type="button" hidden>取消</button>
    </div>
    <div class="ct-form-row">
      <label>
        <span>昵称</span>
        <input id="ct-name" name="name" autocomplete="name" maxlength="80" required />
      </label>
      <label>
        <span>邮箱</span>
        <input id="ct-email" name="email" autocomplete="email" maxlength="120" type="email" />
      </label>
      <label>
        <span>网站</span>
        <input id="ct-link" name="link" autocomplete="url" maxlength="240" type="url" />
      </label>
    </div>
    <label>
      <span>评论</span>
      <textarea id="ct-content" name="content" maxlength="4000" rows="5" required></textarea>
    </label>
    <div class="ct-form-actions">
      <p id="ct-message" class="ct-message"></p>
      <button id="ct-submit" class="ct-button" type="submit">提交</button>
    </div>
  </form>
  <div id="ct-list" class="ct-list"></div>
  <p id="ct-empty" class="ct-empty" hidden>还没有评论。</p>
  <button id="ct-more" class="ct-button ct-more" type="button" hidden>加载更多</button>
</section>

<style>
  .ct-wrap{margin:3rem 0 0;padding-top:1.25rem;border-top:1px solid var(--border)}
  .ct-title{margin:0 0 1rem;font-size:1.35rem}
  .ct-title span{color:var(--muted-foreground);font-size:.95rem;font-weight:500}
  .ct-form{padding:1rem;border:1px solid var(--border);border-radius:8px;background:var(--background)}
  .ct-form-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.75rem}
  .ct-form label{display:flex;flex-direction:column;gap:.35rem;margin-bottom:.75rem;color:var(--muted-foreground);font-size:.82rem}
  .ct-form input,.ct-form textarea{width:100%;box-sizing:border-box;border:1px solid var(--border);border-radius:8px;background:var(--background);color:var(--foreground);padding:.65rem .75rem;font:inherit}
  .ct-form textarea{resize:vertical;line-height:1.55}
  .ct-form-actions{display:flex;align-items:center;gap:.75rem}
  .ct-button{border:0;border-radius:8px;background:var(--accent);color:var(--accent-foreground);cursor:pointer;font-weight:600;padding:.6rem .95rem}
  .ct-button:disabled{cursor:not-allowed;opacity:.55}
  .ct-link-button{border:0;background:transparent;color:var(--muted-foreground);cursor:pointer;padding:0}
  .ct-reply-line{display:flex;align-items:center;gap:.5rem;min-height:1.4rem;margin-bottom:.35rem}
  .ct-reply-hint{border-radius:999px;background:var(--muted);color:var(--muted-foreground);font-size:.78rem;padding:.15rem .55rem}
  .ct-message{flex:1;margin:0;color:var(--muted-foreground);font-size:.82rem}
  .ct-list{margin-top:1.4rem}
  .ct-item{padding:1rem 0;border-bottom:1px solid var(--border)}
  .ct-item-head{display:flex;align-items:flex-start;gap:.65rem}
  .ct-avatar{width:40px;height:40px;border-radius:50%;object-fit:cover;outline:1px solid var(--border)}
  .ct-meta-line{display:flex;align-items:center;flex-wrap:wrap;gap:.35rem;color:var(--muted-foreground);font-size:.78rem}
  .ct-author{color:var(--foreground);font-size:.92rem;font-weight:650}
  .ct-badge,.ct-extra-tag{display:inline-flex;align-items:center;border-radius:999px;background:var(--muted);color:var(--muted-foreground);font-size:.68rem;line-height:1.25rem;padding:0 .55rem}
  .ct-badge-admin{background:color-mix(in srgb,var(--accent) 18%,transparent);color:var(--accent)}
  .ct-source-telegram{background:rgba(126,87,255,.14);color:#7c3aed}
  .ct-source-web{background:var(--muted);color:var(--muted-foreground)}
  :global(html[data-theme="dark"]) .ct-source-telegram{background:rgba(168,139,250,.16);color:#c4b5fd}
  .ct-body{margin-left:calc(40px + .65rem)}
  .ct-content{white-space:pre-wrap;word-break:break-word;line-height:1.65;color:var(--foreground);font-size:.94rem}
  .ct-extra{display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.45rem}
  .ct-reply-btn{margin-top:.45rem;border:0;background:transparent;color:var(--muted-foreground);cursor:pointer;font-size:.78rem;padding:0}
  .ct-reply-btn:hover,.ct-link-button:hover{color:var(--foreground)}
  .ct-children{margin-top:.85rem;margin-left:1.25rem;padding-left:.75rem;border-left:2px solid var(--border)}
  .ct-form-inline{margin-top:.75rem}
  .ct-empty{margin:1.5rem 0;color:var(--muted-foreground);text-align:center}
  .ct-more{width:100%;margin-top:1rem;background:transparent;color:var(--muted-foreground);border:1px solid var(--border)}
  @media(max-width:720px){.ct-form-row{grid-template-columns:1fr}.ct-body{margin-left:0;margin-top:.5rem}.ct-children{margin-left:.5rem;padding-left:.5rem}}
</style>

<script>
  function initComments() {
    const root = document.getElementById("ct-comments");
    if (!root || (root as any).__ctInit) return;
    (root as any).__ctInit = true;
    const api = String(root.dataset.api || "").replace(/\/$/, "");
    if (!api) return;

    const state = {
      page: 1,
      pageSize: Number(root.dataset.pageSize || 20),
      totalPages: 1,
      total: 0,
      loading: false,
      parentId: null as number | null,
      parentName: "",
      comments: [] as any[],
      seenIds: new Set<number>(),
    };

    const pageKey = root.dataset.pageKey || window.location.pathname;
    const pageUrl = root.dataset.pageUrl || window.location.href;
    const pageTitle = root.dataset.pageTitle || document.title;
    const list = document.getElementById("ct-list")!;
    const empty = document.getElementById("ct-empty")!;
    const count = document.getElementById("ct-count")!;
    const more = document.getElementById("ct-more") as HTMLButtonElement;
    const form = document.getElementById("ct-form") as HTMLFormElement;
    const formParent = form.parentNode!;
    const formNext = form.nextSibling;
    const submit = document.getElementById("ct-submit") as HTMLButtonElement;
    const message = document.getElementById("ct-message")!;
    const replyHint = document.getElementById("ct-reply-hint")!;
    const replyCancel = document.getElementById("ct-reply-cancel")!;
    const nameInput = document.getElementById("ct-name") as HTMLInputElement;
    const emailInput = document.getElementById("ct-email") as HTMLInputElement;
    const linkInput = document.getElementById("ct-link") as HTMLInputElement;
    const contentInput = document.getElementById("ct-content") as HTMLTextAreaElement;
    const profileKey = "ct_comment_profile_v1";

    try {
      const saved = JSON.parse(localStorage.getItem(profileKey) || "{}");
      if (typeof saved.name === "string") nameInput.value = saved.name;
      if (typeof saved.email === "string") emailInput.value = saved.email;
      if (typeof saved.link === "string") linkInput.value = saved.link;
    } catch {}

    function showMessage(text: string, isError = false) {
      message.textContent = text || "";
      (message as HTMLElement).style.color = isError ? "#dc2626" : "";
    }

    function dateLabel(value: any) {
      const date = new Date(value);
      if (!Number.isFinite(date.getTime())) return String(value || "");
      return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}-${String(date.getDate()).padStart(2, "0")}`;
    }

    function flagEmoji(code: any) {
      const cc = String(code || "").trim().toUpperCase();
      if (!/^[A-Z]{2}$/.test(cc)) return "";
      return String.fromCodePoint(...[...cc].map(ch => 127397 + ch.charCodeAt(0)));
    }

    function resetFormLocation() {
      form.classList.remove("ct-form-inline");
      formParent.insertBefore(form, formNext);
    }

    function updateReplyUi() {
      if (!state.parentId) {
        replyHint.hidden = true;
        replyCancel.hidden = true;
        replyHint.textContent = "";
        resetFormLocation();
        return;
      }
      replyHint.hidden = false;
      replyCancel.hidden = false;
      replyHint.textContent = `回复 ${state.parentName || "#" + state.parentId}`;
    }

    function treeFromRows(rows: any[]) {
      const map = new Map<number, any>();
      rows.forEach(row => map.set(Number(row.id), { ...row, id: Number(row.id), children: [] }));
      const roots: any[] = [];
      map.forEach(row => {
        const parentId = Number(row.parentId);
        if (Number.isFinite(parentId) && parentId > 0 && map.has(parentId)) {
          map.get(parentId).children.push(row);
        } else {
          roots.push(row);
        }
      });
      const sortRows = (items: any[]) => {
        items.sort((a, b) => new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime() || Number(a.id) - Number(b.id));
        items.forEach(item => sortRows(item.children));
      };
      sortRows(roots);
      return roots;
    }

    function renderComment(comment: any) {
      const item = document.createElement("article");
      item.className = "ct-item";
      const head = document.createElement("div");
      head.className = "ct-item-head";
      const avatar = document.createElement("img");
      avatar.className = "ct-avatar";
      avatar.alt = `${comment.authorName || "Anonymous"} avatar`;
      avatar.loading = "lazy";
      avatar.src = comment.avatarUrl || "https://www.gravatar.com/avatar/?s=160&d=mp&r=g";
      const meta = document.createElement("div");
      meta.className = "ct-meta-line";
      const author = document.createElement("span");
      author.className = "ct-author";
      author.textContent = comment.authorName || "Anonymous";
      meta.appendChild(author);
      if (comment.isAdmin) {
        const badge = document.createElement("span");
        badge.className = "ct-badge ct-badge-admin";
        badge.textContent = "博主";
        meta.appendChild(badge);
      }
      const date = document.createElement("span");
      date.textContent = dateLabel(comment.createdAt);
      meta.appendChild(date);
      head.appendChild(avatar);
      head.appendChild(meta);

      const body = document.createElement("div");
      body.className = "ct-body";
      const text = document.createElement("div");
      text.className = "ct-content";
      text.textContent = comment.content || "";
      body.appendChild(text);

      const extras = document.createElement("div");
      extras.className = "ct-extra";
      const tags: { label: string; className?: string }[] = [];
      const source = String(comment.source || "").toLowerCase();
      if (source === "telegram") tags.push({ label: "Telegram", className: "ct-source-telegram" });
      else if (source === "web") tags.push({ label: "Web", className: "ct-source-web" });
      if (comment.browser) tags.push({ label: String(comment.browser) });
      if (comment.os) tags.push({ label: String(comment.os) });
      if (comment.ipCountry) tags.push({ label: `${flagEmoji(comment.ipCountryCode)} ${comment.ipCountry}`.trim() });
      const asn = String(comment.ipAsn || "").trim();
      const asOrg = String(comment.ipAsOrg || "").trim();
      if (asn || asOrg) tags.push({ label: [asn, asOrg].filter(Boolean).join(" ") });
      tags.forEach(({ label, className }) => {
        const tag = document.createElement("span");
        tag.className = `ct-extra-tag${className ? ` ${className}` : ""}`;
        tag.textContent = label;
        extras.appendChild(tag);
      });
      if (tags.length) body.appendChild(extras);

      const reply = document.createElement("button");
      reply.className = "ct-reply-btn";
      reply.type = "button";
      reply.textContent = "回复";
      reply.addEventListener("click", () => {
        state.parentId = Number(comment.id);
        state.parentName = String(comment.authorName || "");
        updateReplyUi();
        form.classList.add("ct-form-inline");
        item.appendChild(form);
        contentInput.focus();
      });
      body.appendChild(reply);

      item.appendChild(head);
      item.appendChild(body);

      if (Array.isArray(comment.children) && comment.children.length) {
        const children = document.createElement("div");
        children.className = "ct-children";
        comment.children.forEach((child: any) => children.appendChild(renderComment(child)));
        item.appendChild(children);
      }
      return item;
    }

    function render() {
      list.innerHTML = "";
      treeFromRows(state.comments).forEach(comment => list.appendChild(renderComment(comment)));
      empty.hidden = state.total !== 0;
    }

    async function load(reset = false) {
      if (state.loading) return;
      state.loading = true;
      more.disabled = true;
      try {
        if (reset) {
          state.page = 1;
          state.comments = [];
          state.seenIds = new Set();
        }
        const url = new URL(`${api}/v1/comments`);
        url.searchParams.set("pageKey", pageKey);
        url.searchParams.set("page", String(state.page));
        url.searchParams.set("pageSize", String(state.pageSize));
        const response = await fetch(url.toString(), { method: "GET", credentials: "omit" });
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data?.error?.message || `加载评论失败 (${response.status})`);
        state.total = Number(data.pagination?.total || 0);
        state.totalPages = Number(data.pagination?.totalPages || 1);
        count.textContent = String(state.total);
        (Array.isArray(data.comments) ? data.comments : []).forEach((comment: any) => {
          const id = Number(comment.id);
          if (!Number.isFinite(id) || state.seenIds.has(id)) return;
          state.seenIds.add(id);
          state.comments.push(comment);
        });
        render();
        more.hidden = !(state.page < state.totalPages);
        more.disabled = false;
      } catch (error) {
        showMessage(error instanceof Error ? error.message : "加载评论失败", true);
      } finally {
        state.loading = false;
      }
    }

    more.addEventListener("click", async () => {
      if (state.page >= state.totalPages || state.loading) return;
      state.page += 1;
      await load(false);
    });

    replyCancel.addEventListener("click", () => {
      state.parentId = null;
      state.parentName = "";
      showMessage("");
      updateReplyUi();
    });

    form.addEventListener("submit", async event => {
      event.preventDefault();
      if (state.loading) return;
      const payload = {
        pageUrl,
        pageKey,
        pageTitle,
        authorName: String(nameInput.value || "").trim(),
        authorEmail: String(emailInput.value || "").trim(),
        authorLink: String(linkInput.value || "").trim(),
        content: String(contentInput.value || "").trim(),
        parentId: state.parentId,
      };
      if (!payload.authorName || !payload.content) {
        showMessage("昵称和评论内容为必填项。", true);
        return;
      }
      state.loading = true;
      submit.disabled = true;
      showMessage("提交中...");
      try {
        localStorage.setItem(profileKey, JSON.stringify({ name: payload.authorName, email: payload.authorEmail, link: payload.authorLink }));
        const response = await fetch(`${api}/v1/comments`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data?.error?.message || `发表评论失败 (${response.status})`);
        showMessage(data.comment?.status === "pending" ? "已提交，等待审核。" : "评论已发表。");
        contentInput.value = "";
        state.parentId = null;
        state.parentName = "";
        updateReplyUi();
        state.loading = false;
        await load(true);
      } catch (error) {
        showMessage(error instanceof Error ? error.message : "发表评论失败", true);
      } finally {
        state.loading = false;
        submit.disabled = false;
      }
    });

    updateReplyUi();
    load(true);
  }

  document.addEventListener("astro:page-load", initComments);
  initComments();
</script>
